---
import { type Locale, useTranslations } from '../i18n/ui';
import { stackData } from '../data/site';
import { localizedPath } from '../i18n/ui';

interface Props {
  locale: Locale;
  compact?: boolean;
}

const { locale, compact = false } = Astro.props;
const t = useTranslations(locale);
---

<section class={compact ? '' : 'py-4'}>
  {
    !compact && (
      <>
        <h2 class="text-2xl font-bold text-white">{t.stack.title}</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">{t.stack.subtitle}</p>
      </>
    )
  }

  <div class={`grid gap-6 ${compact ? 'mt-0 sm:grid-cols-3' : 'mt-8 sm:grid-cols-3'}`}>
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-accent)]">
        {t.stack.principal}
      </h3>
      <ul class="mt-3 space-y-2">
        {
          stackData.principal.map((item) => (
            <li class="text-sm text-white">{item}</li>
          ))
        }
      </ul>
    </div>

    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-emerald-400">
        {t.stack.solid}
      </h3>
      <ul class="mt-3 space-y-2">
        {
          stackData.solid.map((item) => (
            <li class="text-sm text-[var(--color-text-muted)]">{item}</li>
          ))
        }
      </ul>
    </div>

    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-amber-400">
        {t.stack.learning}
      </h3>
      <ul class="mt-3 space-y-2">
        {
          stackData.learning.map((item) => (
            <li class="text-sm text-[var(--color-text-muted)]">{item}</li>
          ))
        }
      </ul>
    </div>
  </div>

  {
    compact && (
      <div class="mt-6">
        <a
          href={localizedPath('/stack', locale)}
          class="text-sm font-medium text-[var(--color-accent)] hover:underline"
        >
          {t.stack.viewAll} →
        </a>
      </div>
    )
  }
</section>
