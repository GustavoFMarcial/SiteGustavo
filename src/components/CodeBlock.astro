---
import { Code } from 'astro:components';

interface Props {
  title: string;
  caption: string;
  code: string;
  lang?: string;
}

const { title, caption, code, lang = 'csharp' } = Astro.props;
---

<div class="overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
  <div class="border-b border-[var(--color-border)] px-4 py-3">
    <h3 class="font-mono text-base font-medium text-white">{title}</h3>
    <p class="mt-1 text-base text-[var(--color-text-muted)]">{caption}</p>
  </div>
  <div class="overflow-x-auto p-4 text-sm [&_pre]:!bg-transparent [&_pre]:!p-0">
    <Code code={code} lang={lang} theme="github-dark" />
  </div>
</div>
