---
import {
  type Locale,
  useTranslations,
  localizedPath,
  switchLocalePath,
} from '../i18n/ui';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);
const otherLocale = locale === 'pt' ? 'en' : 'pt';
const switchPath = switchLocalePath(currentPath, otherLocale);

const navItems = [
  { href: localizedPath('/', locale), label: t.nav.home },
  { href: localizedPath('/projetos', locale), label: t.nav.projects },
  { href: localizedPath('/stack', locale), label: t.nav.stack },
  { href: localizedPath('/contato', locale), label: t.nav.contact },
];
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-surface)]/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 sm:px-6">
    <a
      href={localizedPath('/', locale)}
      class="text-base font-semibold tracking-tight text-white hover:text-[var(--color-accent)] transition-colors"
    >
      Gustavo Marcial
    </a>

    <nav class="hidden items-center gap-6 sm:flex" aria-label="Main">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-base text-[var(--color-text-muted)] hover:text-white transition-colors"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={switchPath}
        class="rounded-md border border-[var(--color-border)] px-2.5 py-1 text-sm font-medium text-[var(--color-text-muted)] hover:border-[var(--color-accent)] hover:text-white transition-colors"
        aria-label={otherLocale === 'en' ? 'Switch to English' : 'Mudar para Português'}
      >
        {otherLocale.toUpperCase()}
      </a>
    </div>
  </div>

  <nav
    class="flex gap-4 overflow-x-auto border-t border-[var(--color-border)] px-4 py-2 sm:hidden"
    aria-label="Mobile"
  >
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class="whitespace-nowrap text-sm text-[var(--color-text-muted)] hover:text-white"
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
