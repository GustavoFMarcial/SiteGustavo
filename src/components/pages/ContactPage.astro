---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../Button.astro';
import { type Locale, useTranslations } from '../../i18n/ui';
import { links } from '../../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout locale={locale} title={t.nav.contact} description={t.contact.subtitle}>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">{t.contact.title}</h1>
    <p class="mt-3 text-base text-[var(--color-text-muted)]">{t.contact.subtitle}</p>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-accent)]">
          {t.contact.email}
        </h2>
        <a
          href={`mailto:${links.email}`}
          class="mt-3 block text-xl text-white hover:text-[var(--color-accent)] transition-colors"
        >
          {links.email}
        </a>
      </div>

      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-6">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-accent)]">
          {t.contact.links}
        </h2>
        <div class="mt-4 flex flex-wrap gap-3">
          <Button href={links.github} label="GitHub" external variant="secondary" />
          <Button href={links.linkedin} label="LinkedIn" external variant="secondary" />
          <Button href={links.cv} label={t.hero.resume} variant="secondary" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
