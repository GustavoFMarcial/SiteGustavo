---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../Button.astro';
import StackSection from '../StackSection.astro';
import ImageLightbox from '../ImageLightbox.astro';
import { type Locale, useTranslations, localizedPath } from '../../i18n/ui';
import { links } from '../../data/site';
import { getProject } from '../../data/projects';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const featured = getProject('anunciecompre', locale);
---

<BaseLayout locale={locale}>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
    <p class="text-base font-medium text-[var(--color-accent)]">Engineering Notebook</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-white sm:text-5xl">
      {t.hero.name}
    </h1>
    <p class="mt-4 max-w-2xl text-xl text-[var(--color-text-muted)]">
      {t.hero.headline}
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <Button
        href={links.github}
        label="GitHub"
        external
        variant="secondary"
      />
      <Button
        href={links.linkedin}
        label="LinkedIn"
        external
        variant="secondary"
      />
      <Button href={links.cv} label={t.hero.resume} variant="secondary" />
      <Button
        href={`mailto:${links.email}`}
        label={t.nav.contact}
        variant="secondary"
      />
      <Button
        href={localizedPath('/projetos', locale)}
        label={t.hero.viewProjects}
        variant="primary"
      />
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-16 sm:px-6">
    <h2 class="text-2xl font-bold text-white">{t.intro.title}</h2>
    <div class="mt-6 max-w-3xl space-y-4 text-base text-[var(--color-text-muted)] leading-relaxed">
      <p>{t.intro.p1}</p>
      <p>{t.intro.p2}</p>
      <p>{t.intro.p3}</p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-16 sm:px-6">
    <div class="flex items-center gap-3">
      <h2 class="text-2xl font-bold text-white">{t.featured.title}</h2>
      <span class="rounded-full bg-[var(--color-accent-muted)] px-3 py-0.5 text-sm font-medium text-[var(--color-accent)]">
        {t.featured.badge}
      </span>
    </div>

    <article class="mt-8 overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
      <div class="grid lg:grid-cols-2">
        <div class="p-6 sm:p-8">
          <div class="flex flex-wrap items-center gap-2">
            <h3 class="text-2xl font-bold text-white">{featured.title}</h3>
            <span class="rounded-full bg-blue-950 px-2.5 py-0.5 text-sm font-medium text-blue-400">
              {t.projects.inDevelopment}
            </span>
          </div>
          <p class="mt-1 text-xl text-[var(--color-accent)]">{featured.tagline}</p>
          <p class="mt-4 text-base leading-relaxed text-[var(--color-text-muted)]">
            {featured.description}
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {
              featured.stack.slice(0, 4).map((tech) => (
                <span class="rounded-md bg-[var(--color-surface)] px-2 py-1 text-sm text-[var(--color-text-muted)]">
                  {tech}
                </span>
              ))
            }
          </div>
          <div class="mt-6">
            <Button
              href={localizedPath(`/projetos/${featured.slug}`, locale)}
              label={t.projects.viewProject}
              variant="primary"
            />
          </div>
        </div>
        <div class="border-t border-[var(--color-border)] bg-[var(--color-surface)] lg:border-t-0 lg:border-l">
          <ImageLightbox
            src={featured.images[1]?.src ?? featured.images[0].src}
            alt={featured.images[1]?.alt ?? featured.images[0].alt}
            id="home-anunciecompre"
            enlargeLabel={t.projects.clickToEnlarge}
            class="h-full object-top p-2"
          />
        </div>
      </div>
    </article>
  </section>

  <section class="mx-auto max-w-5xl px-4 pb-24 sm:px-6">
    <StackSection locale={locale} compact />
  </section>
</BaseLayout>
