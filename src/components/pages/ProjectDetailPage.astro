---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../Button.astro';
import CodeBlock from '../CodeBlock.astro';
import ImageLightbox from '../ImageLightbox.astro';
import { type Locale, useTranslations, localizedPath } from '../../i18n/ui';
import { getProject, type ProjectSlug } from '../../data/projects';

interface Props {
  locale: Locale;
  slug: ProjectSlug;
}

const { locale, slug } = Astro.props;
const t = useTranslations(locale);
const project = getProject(slug, locale);
const sectionLabels =
  locale === 'pt'
    ? {
        stack: 'Stack',
        patterns: 'Arquitetura',
        highlights: 'Funcionalidades',
        shows: t.projects.whatItShows,
        gallery: 'Demo',
        code: 'Código em contexto',
        roadmap: 'Roadmap',
        done: 'Implementado',
        planned: 'Próximos passos',
        back: '← Voltar aos projetos',
      }
    : {
        stack: 'Stack',
        patterns: 'Architecture',
        highlights: 'Features',
        shows: t.projects.whatItShows,
        gallery: 'Demo',
        code: 'Code in context',
        roadmap: 'Roadmap',
        done: 'Implemented',
        planned: 'Next steps',
        back: '← Back to projects',
      };
---

<BaseLayout locale={locale} title={project.title} description={project.description}>
  <article class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <a
      href={localizedPath('/projetos', locale)}
      class="text-base text-[var(--color-text-muted)] hover:text-[var(--color-accent)]"
    >
      {sectionLabels.back}
    </a>

    <header class="mt-6">
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-3xl font-bold text-white sm:text-4xl">{project.title}</h1>
        {
          project.status === 'in-development' && (
            <span class="rounded-full bg-blue-950 px-3 py-0.5 text-sm font-medium text-blue-400">
              {t.projects.inDevelopment}
            </span>
          )
        }
        {
          project.status === 'completed' && (
            <span class="rounded-full bg-emerald-950 px-3 py-0.5 text-sm font-medium text-emerald-400">
              {t.projects.completed}
            </span>
          )
        }
        {
          project.github && (
            <span class="rounded-full bg-emerald-950/60 px-3 py-0.5 text-sm font-medium text-emerald-400">
              {t.projects.openSource}
            </span>
          )
        }
        {
          project.isPrivate && (
            <span class="rounded-full bg-amber-950/60 px-3 py-0.5 text-sm font-medium text-amber-400">
              {t.projects.privateCode}
            </span>
          )
        }
      </div>
      <p class="mt-2 text-xl text-[var(--color-accent)]">{project.tagline}</p>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-[var(--color-text-muted)]">
        {project.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        {
          project.github && (
            <Button
              href={project.github}
              label={t.projects.sourceCode}
              external
              variant="primary"
            />
          )
        }
      </div>
    </header>

    <section class="mt-12">
      <h2 class="text-xl font-semibold text-white">{sectionLabels.stack}</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          project.stack.map((tech) => (
            <span class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-elevated)] px-3 py-1.5 text-base text-[var(--color-text-muted)]">
              {tech}
            </span>
          ))
        }
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-xl font-semibold text-white">{sectionLabels.patterns}</h2>
      <ul class="mt-4 grid gap-2 sm:grid-cols-2">
        {
          project.patterns.map((pattern) => (
            <li class="flex items-center gap-2 text-base text-[var(--color-text-muted)]">
              <span class="text-[var(--color-accent)]">✔</span>
              {pattern}
            </li>
          ))
        }
      </ul>
    </section>

    {
      project.methodology && project.methodology.length > 0 && (
        <section class="mt-10">
          <h2 class="text-xl font-semibold text-white">{t.projects.methodology}</h2>
          <ul class="mt-4 space-y-2">
            {
              project.methodology.map((item) => (
                <li class="flex items-start gap-2 text-base text-[var(--color-text-muted)]">
                  <span class="mt-0.5 w-5 shrink-0 text-[var(--color-accent)]">→</span>
                  {item}
                </li>
              ))
            }
          </ul>
        </section>
      )
    }

    <section class="mt-10">
      <h2 class="text-xl font-semibold text-white">{sectionLabels.highlights}</h2>
      <ul class="mt-4 space-y-2">
        {
          project.highlights.map((item) => (
            <li class="text-base text-[var(--color-text-muted)]">• {item}</li>
          ))
        }
      </ul>
    </section>

    <section class="mt-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-accent-muted)]/30 p-6">
      <h2 class="text-xl font-semibold text-white">{sectionLabels.shows}</h2>
      <ul class="mt-4 space-y-2">
        {
          project.showsAboutMe.map((item) => (
            <li class="flex items-start gap-2 text-base text-[var(--color-text-muted)]">
              <span class="mt-0.5 w-5 shrink-0 text-[var(--color-accent)]">→</span>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    {
      project.roadmap && (
        <section class="mt-10">
          <h2 class="text-xl font-semibold text-white">{sectionLabels.roadmap}</h2>
          <div class="mt-4 grid items-start gap-6 sm:grid-cols-2">
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5">
              <h3 class="text-base font-medium text-emerald-400">{sectionLabels.done}</h3>
              <ul class="mt-3 space-y-2">
                {project.roadmap.done.map((item) => (
                  <li class="flex items-start gap-2 text-base text-[var(--color-text-muted)]">
                    <span class="w-5 shrink-0 text-emerald-400">✓</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)] p-5">
              <h3 class="text-base font-medium text-amber-400">{sectionLabels.planned}</h3>
              <ul class="mt-3 space-y-2">
                {project.roadmap.planned.map((item) => (
                  <li class="flex items-start gap-2 text-base text-[var(--color-text-muted)]">
                    <span class="w-5 shrink-0 text-amber-400">□</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      )
    }

    <section class="mt-12">
      <h2 class="text-xl font-semibold text-white">{sectionLabels.gallery}</h2>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">{t.projects.clickToEnlarge}</p>
      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        {
          project.images.map((image, index) => (
            <figure class="overflow-hidden rounded-xl border border-[var(--color-border)]">
              <ImageLightbox
                src={image.src}
                alt={image.alt}
                id={`${project.slug}-${index}`}
                enlargeLabel={t.projects.clickToEnlarge}
                class="p-2"
                imgClass="max-h-80 w-full object-contain"
              />
              <figcaption class="px-4 py-2 text-sm text-[var(--color-text-muted)]">
                {image.alt}
              </figcaption>
            </figure>
          ))
        }
      </div>
    </section>

    {
      project.codeSections && project.codeSections.length > 0 && (
        <section class="mt-12">
          <h2 class="text-xl font-semibold text-white">{sectionLabels.code}</h2>
          <div class="mt-6 space-y-6">
            {project.codeSections.map((section) => (
              <CodeBlock
                title={section.title}
                caption={section.caption}
                code={section.code}
              />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
