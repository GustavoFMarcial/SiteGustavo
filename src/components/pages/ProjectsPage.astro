---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../Button.astro';
import { type Locale, useTranslations, localizedPath } from '../../i18n/ui';
import { getAllProjects } from '../../data/projects';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const projects = getAllProjects(locale);
---

<BaseLayout
  locale={locale}
  title={t.nav.projects}
  description={t.projects.subtitle}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-bold text-white sm:text-4xl">{t.projects.title}</h1>
    <p class="mt-3 text-[var(--color-text-muted)]">{t.projects.subtitle}</p>

    <div class="mt-12 grid gap-8">
      {
        projects.map((project) => (
          <article class="overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-elevated)]">
            <div class="grid md:grid-cols-2">
              <img
                src={project.images[0].src}
                alt={project.images[0].alt}
                class="h-56 w-full object-cover object-top md:h-full"
                loading="lazy"
              />
              <div class="flex flex-col p-6 sm:p-8">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="text-2xl font-bold text-white">{project.title}</h2>
                    <p class="mt-1 text-sm text-[var(--color-accent)]">{project.tagline}</p>
                  </div>
                  {project.github ? (
                    <span class="shrink-0 rounded-full bg-emerald-950 px-2.5 py-0.5 text-xs font-medium text-emerald-400">
                      {t.projects.openSource}
                    </span>
                  ) : (
                    <span class="shrink-0 rounded-full bg-amber-950 px-2.5 py-0.5 text-xs font-medium text-amber-400">
                      Private
                    </span>
                  )}
                </div>
                <p class="mt-4 flex-1 text-sm leading-relaxed text-[var(--color-text-muted)]">
                  {project.description}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {project.stack.slice(0, 5).map((tech) => (
                    <span class="rounded-md bg-[var(--color-surface)] px-2 py-1 text-xs text-[var(--color-text-muted)]">
                      {tech}
                    </span>
                  ))}
                </div>
                <div class="mt-6">
                  <Button
                    href={localizedPath(`/projetos/${project.slug}`, locale)}
                    label={t.projects.viewProject}
                    variant="primary"
                  />
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
